{
  "manifest_version": 2,
  "name": "Xmusic",
  "version": "1.3",
  "description": "Upload audio to chat on express.ms",
  "permissions": [
    "https://corp.express/*",
    "activeTab",
    "microphone"
  ],
  "browser_action": {
    "default_title": "Audio Uploader",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  },
  "license": "GPL-3.0",
  "browser_specific_settings": {
    "gecko": {
    "id": "xmusic@corp.express_new",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required":  ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://corp.express/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}