// Проверяем store
if (!window.__store) {
    console.error(' Store не найден!');
} else {
    var input = document.createElement('input');
    input.type = 'file';
    input.accept = 'audio/*';
    input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        // Имитируем полную мета-информацию, которую создает функция getFileMeta в коде
        // (взято из модуля 83486, компонент Attachments)
        const fileMeta = {
            // Основные поля
            name: file.name,
            type: file.type,
            file: file,
            // ВАЖНО: Эти флаги отвечают за отображение правильной иконки и плеера
            isImage: false,
            isVideo: false,
            isDocument: false,
            isVoice: true,  // <-- ГЛАВНЫЙ ФЛАГ ДЛЯ АУДИО
            // Доп поля для совместимости
            attachmentType: 'voice',
            size: (file.size / 1048576).toFixed(2) + ' MB',
            preview: null,
            // Заглушки для безопасности
            disallowToUploadReason: null,
            isDisallowedToUploadFile: false
        };
        console.log(' Отправляем подготовленный аудио-объект:', fileMeta);
        // Отправляем в Redux
        window.__store.dispatch({
            type: 'ADD_CURRENT_CHAT_ATTACHMENTS',
            payload: { attachments: [fileMeta] }
        });
        // Дополнительно: иногда приложению нужно явно открыть панель вложений.
        // Попробуем также установить флаг isAttachDialogOpen через другой экшен (если первый не сработает)
        // Это не обязательно, но может помочь.
        setTimeout(() => {
            window.__store.dispatch({
                type: 'SET_CURRENT_CHAT_ATTACHMENTS',
                payload: { attachments: [fileMeta] }
            });
        }, 10);
    };
    input.click();
}
