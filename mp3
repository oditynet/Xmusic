function findStore() {
    // Способ 1: Стандартный для React 18 с createRoot
    try {
        const rootKey = Object.keys(document.querySelector('#app')).find(key => key.startsWith('__reactContainer'));
        if (rootKey) {
            const fiber = document.querySelector('#app')[rootKey];
            let node = fiber;
            while (node) {
                if (node.memoizedState?.element?.props?.store) {
                    console.log('✅ Store найден через React 18 root!');
                    return node.memoizedState.element.props.store;
                }
                node = node.child;
            }
        }
    } catch (e) {}

    // Способ 2: Поиск по всем глобальным переменным
    const possibleNames = ['store', '__store', '__REDUX_STORE__', '__REACT_DEVTOOLS_GLOBAL_HOOK__'];
    for (let name in window) {
        if (possibleNames.includes(name) || (window[name] && typeof window[name].dispatch === 'function' && typeof window[name].getState === 'function')) {
            console.log('✅ Store найден в window.' + name);
            return window[name];
        }
    }

    // Способ 3: Через Redux DevTools (если подключены)
    if (window.__REDUX_DEVTOOLS_EXTENSION__) {
        console.log('ℹ️ Redux DevTools найдены, но store не вычислен. Попробуйте открыть вкладку Redux.');
    }

    console.error('❌ Не удалось найти Store автоматически.');
    return null;
}

const STORE = findStore();
if (STORE) {
    window.__store = STORE;
    console.log('Store успешно сохранен в window.__store');
} else {
    console.log('Попробуйте вручную: откройте React DevTools -> Выделите <Provider> -> Сохраните $r.store');
}


